# ═══════════════════════════════════════════════════════════════════════════
# POS BOT — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════
# Ushbu faylni .env sifatida nushasini olib, kerakli qiymatlarni to'ldiring.
# ⚠️ PRODUCTION: HECH QACHON .env faylini GitHub'ga push qilmang!

# ───────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT (REQUIRED)
# ───────────────────────────────────────────────────────────────────────────

# Bot token'i (https://t.me/BotFather orqali olinadi)
BOT_TOKEN=tokeningiz

# Bosh admin'ning Telegram ID (integer, masalan: 123456789)
GLAVNIY_ADMIN_ID=telegram_idingiz

# Kanal ID (xabarlarnomalar yuboriladi, @kanalname yoki -1001234567890)
CHANNEL_ID=@kanal_username

# ───────────────────────────────────────────────────────────────────────────
# MA'LUMOTLAR JOYLASHUVI (DATA / STORAGE)
# ───────────────────────────────────────────────────────────────────────────
# Jonli ma'lumotlar (pos.db, uploads/, exports/, backups/) KOD DARAXTIDAN
# TASHQARIDA turishi kerak. Bo'sh qoldirilsa — repo ildizidagi `data/`
# ishlatiladi (chinor-bot manba papkasi EMAS → `git clean` baza yo'qotmaydi).
#
# PRODUCTION'da kod tashqarisidagi doimiy yo'lni ko'rsating, masalan:
#   DATA_DIR=/var/lib/chinor
# DB_PATH va UPLOAD_DIR DATA_DIR'dan kelib chiqadi; xohlasangiz alohida
# (masalan boshqa diskka) yo'naltirish uchun ularni ham belgilashingiz mumkin.
DATA_DIR=
# DB_PATH=
# UPLOAD_DIR=

# ───────────────────────────────────────────────────────────────────────────
# BACKUP & MAINTENANCE
# ───────────────────────────────────────────────────────────────────────────

# Avtomatik backup oraliq vaqti (soatda, 0 = o'chirilgan)
BACKUP_INTERVAL_HOURS=24

# ───────────────────────────────────────────────────────────────────────────
# TIME & CURRENCY
# ───────────────────────────────────────────────────────────────────────────

# Vaqt mintaqasi UTC offset (Toshkent = 5, UTC+5)
TZ_OFFSET_HOURS=5

# USD → So'm boshlang'ich kursi (admin keyinchalik o'zgartira oladi)
USD_RATE=12500

# ───────────────────────────────────────────────────────────────────────────
# ALERTS & NOTIFICATIONS
# ───────────────────────────────────────────────────────────────────────────

# Past qoldiq ostonasi (0 = faqat tugaganda xabar, tavsiyalangan)
LOW_STOCK_THRESHOLD=0

# ───────────────────────────────────────────────────────────────────────────
# MINI APP (WebApp) — OPTIONAL
# ───────────────────────────────────────────────────────────────────────────

# Mini App'ning to'liq HTTPS URL'i (Netlify/Vercel/custom)
# Bo'sh qolsa Mini App tugmasi ko'rinmaydi
MINI_APP_URL=https://your-domain.netlify.app

# ───────────────────────────────────────────────────────────────────────────
# API SERVER (Mini App uchun) — OPTIONAL
# ───────────────────────────────────────────────────────────────────────────

# API server bind addressi (0.0.0.0 = barcha interfeys)
API_HOST=0.0.0.0

# API server port
API_PORT=8765

# API faolmi (1 = faol, 0 = o'chirilgan)
API_ENABLED=1

# ⚠️ CORS RUXSATI — Juda muhim xavfsizlik sozlamasi!
# Vergul bilan ajratilgan domenlar (masalan: https://domain1.com,https://domain2.com)
# HECH QACHON "*" bo'lmasin! (Bu juda zaif)
# RECOMMENDED: MINI_APP_URL qiymatini shu yerga qo'shish
CORS_ALLOW_ORIGIN=https://your-domain.netlify.app

# ───────────────────────────────────────────────────────────────────────────
# GOOGLE GEMINI AI (optional)
# ───────────────────────────────────────────────────────────────────────────

# Gemini API kaliti (https://aistudio.google.com/app/apikey)
# Bo'sh qolsa AI funksiyalar o'chiriladi
GEMINI_API_KEY=

# Gemini model nomi (standart: gemini-2.5-flash tavsiyalangan)
GEMINI_MODEL=gemini-2.5-flash

# ───────────────────────────────────────────────────────────────────────────
# LOGGING (optional)
# ───────────────────────────────────────────────────────────────────────────

# LOG_LEVEL=INFO
# LOG_FILE=/var/log/pos_bot.log

# ═══════════════════════════════════════════════════════════════════════════
# ⚠️ SECURITY REMINDERS
# ═══════════════════════════════════════════════════════════════════════════
# 1. HECH QACHON BOT_TOKEN, GEMINI_API_KEY, va boshqa secrets'ni public jo'natmang
# 2. .env faylini .gitignore'ga qo'shish (hozir qo'shilgan bo'lishi kerak)
# 3. Production'da secrets manager (Vault, AWS Secrets, etc.) ishlatish tavsiyalangan
# 4. CORS_ALLOW_ORIGIN HECH QACHON "*" bo'lmasin!
# 5. Barcha sensitive logs'ni production'da o'chirib qo'yish kerak
# Bo'sh qoldirsangiz — '🤖 AI Analitika' tugmasi sozlanmagan deb javob beradi.
GEMINI_API_KEY=
# Tavsiya etilgan modellar (2025-yil oxiri holatiga):
#   gemini-2.5-flash       — tez va arzon (default)
#   gemini-2.5-pro         — sifatliroq, sekinroq
#   gemini-flash-latest    — Google avtomatik eng yangi flash'ga ulaydi
#   gemini-pro-latest      — Google avtomatik eng yangi pro'ga ulaydi
# DIQQAT: gemini-1.5-* modellari eskirgan (404 not found xatosi keladi).
GEMINI_MODEL=gemini-2.5-flash

# ── Mini App va HTTPS API ────────────────────────────────────────────────
# Mini App'ning Telegram'da ochiladigan to'liq HTTPS manzili
MINI_APP_URL=

# Bot bilan birga aiohttp HTTPS API serveri ishga tushadi.
# Frontend POST /api/login yuborib login qiladi, javobiga qarab admin yoki
# klient panelini WebApp ichida ochadi.
API_ENABLED=1
API_HOST=0.0.0.0
API_PORT=8765
# Frontend domeningiz (CORS uchun). * yozsangiz har qanday joydan ruxsat —
# faqat test uchun ishlatish tavsiya etiladi.
CORS_ALLOW_ORIGIN=
